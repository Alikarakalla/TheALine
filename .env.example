# ─────────────────────────────────────────────────────────────────────────────
# The A Line — environment configuration
# Copy this file to ".env" and fill in real values. ".env" is gitignored.
# The frontend reads VITE_* at BUILD time; the PHP backend reads the rest at RUN
# time. For local XAMPP dev you usually need NO .env at all (defaults below work).
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend (Vite — baked into the build by `npm run build`) ────────────────
# Base URL the storefront/admin call.
#   Local XAMPP : http://localhost/lovebag/api
#   Hostinger   : https://YOUR-DOMAIN.com/api
VITE_API_BASE=http://localhost/lovebag/api

# ── Backend (PHP — read at runtime by /server) ───────────────────────────────
# MySQL — create the database + user in Hostinger hPanel → Databases → MySQL.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# Secret used to sign admin/customer login tokens. Use a long random string.
# Generate one with:  php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL=604800

# Public URL the uploaded product images are served from (the /uploads folder).
#   Hostinger : https://YOUR-DOMAIN.com/api/uploads
UPLOAD_URL=https://YOUR-DOMAIN.com/api/uploads

# Browser origins allowed to call the API (comma-separated). Leave blank when the
# storefront and API share one domain. Set it if the API is on a subdomain, e.g.:
#   CORS_ORIGINS=https://YOUR-DOMAIN.com,https://www.YOUR-DOMAIN.com
CORS_ORIGINS=

# Only set if path auto-detection fails (rare):
#   Local XAMPP: /lovebag/api   Hostinger (public_html/api): /api
# API_BASE_PATH=/api
