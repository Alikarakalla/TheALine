# Normalize line endings in the repo (silences CRLF/LF warnings on Windows).
* text=auto

# These MUST stay LF — CRLF breaks bash scripts and can break Apache .htaccess.
*.sh      text eol=lf
.htaccess text eol=lf

# Treat binary assets as binary (no EOL conversion).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.woff  binary
*.woff2 binary
