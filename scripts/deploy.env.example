# Copy this file to scripts/deploy.env (gitignored) and fill in your values.
# Find them in hPanel -> Advanced -> SSH Access.

SSH_HOST=123.45.67.89        # your server IP / hostname from hPanel
SSH_USER=u123456789          # your SSH username from hPanel
SSH_PORT=65002               # Hostinger shared hosting SSH port (usually 65002)

# Web root to deploy into, relative to your SSH home directory:
#   primary domain : public_html
#   addon domain   : domains/your-domain.com/public_html
REMOTE_PATH=public_html
