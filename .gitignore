# Dependencies
node_modules/

# Build output (the storefront is built into /public, the web root)
public/
dist/
dist-ssr/
*.local

# Environment / secrets (matches root .env and api/.env)
.env
.env.*
!.env.example

# Uploaded product images (user content, not source). Keep the folder via .gitkeep.
api/uploads/*
!api/uploads/.gitkeep

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# TypeScript incremental build cache
*.tsbuildinfo

# Editor / OS
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/

# Claude Code / local agent tooling
.claude/
