# The A Line storefront — SPA fallback for React Router.
# Vite copies everything in /public into the build, so this ships inside dist/
# and lands in public_html on Hostinger.
RewriteEngine On

# Leave the API alone — it has its own .htaccess in /api.
RewriteRule ^api(/|$) - [L]

# Serve real files and directories directly (assets, images, etc.).
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Everything else -> the SPA entry point so deep links / refreshes work.
RewriteRule ^ index.html [L]
